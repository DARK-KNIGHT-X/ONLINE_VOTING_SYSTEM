@model VotingViewModel
@{
    ViewData["Title"] = "Cast Your Vote";
}

<div class="container py-5">
    <h2 class="fw-bold text-center text-purple mb-2">Cast Your Vote</h2>
    <p class="text-muted text-center mb-5">Constituency: <strong>@Model.VoterConstituency</strong></p>

    @if (!Model.Candidates.Any())
    {
        <div class="alert alert-info text-center">No candidates found for your constituency yet. Please check back later.</div>
    }
    else
    {
        <form asp-action="CastVote" method="post">
            <div class="row g-4 justify-content-center">
                @foreach (var candidate in Model.Candidates)
                {
                    <div class="col-md-4">
                        <div class="card candidate-card border-0 shadow-sm p-4 text-center h-100">
                            <div class="candidate-avatar mx-auto mb-3">
                                <i class="fas fa-user-tie fa-2x text-purple"></i>
                            </div>
                            <h5 class="fw-bold">@candidate.FullName</h5>
                            <span class="badge bg-purple mb-2">@candidate.Party</span>
                            <p class="text-muted small">@candidate.Constituency</p>
                            <button type="submit" name="candidateId" value="@candidate.Id"
                                class="btn btn-purple mt-auto"
                                onclick="return confirm('Are you sure you want to vote for @candidate.FullName (@candidate.Party)? This action cannot be undone.')">
                                <i class="fas fa-check-circle me-1"></i> Vote
                            </button>
                        </div>
                    </div>
                }
            </div>
        </form>
    }
</div>
