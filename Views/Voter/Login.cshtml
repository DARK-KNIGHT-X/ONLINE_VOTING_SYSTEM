@model VoterLoginViewModel
@{
    ViewData["Title"] = "Voter Login";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4">
                <div class="text-end mb-2">
                    <a asp-controller="Voter" asp-action="Register" class="btn btn-sm btn-outline-secondary">New voter? Register</a>
                </div>
                <h4 class="fw-bold text-center mb-1">Voter Login</h4>
                <p class="text-muted text-center small mb-4">Sign in to cast your vote</p>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="EpicNumber" class="form-label small fw-semibold">EPIC Number (Voter ID)</label>
                        <input asp-for="EpicNumber" class="form-control" placeholder="EPIC1001" />
                        <span asp-validation-for="EpicNumber" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Your password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-purple w-100">Login</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
