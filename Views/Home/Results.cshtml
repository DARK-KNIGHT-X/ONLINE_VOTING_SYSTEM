@model ResultsViewModel
@{
    ViewData["Title"] = "Election Results";
}

<div class="container py-5">
    <h2 class="fw-bold text-center text-purple mb-4">Election Results</h2>

    @if (!Model.IsDeclared)
    {
        <div class="alert alert-warning text-center">
            <i class="fas fa-clock me-2"></i> Results have not been declared yet. Please check back later.
        </div>
    }
    else
    {
        <!-- Winner Banner -->
        <div class="card border-0 shadow-sm mb-4 bg-purple-light text-center p-4">
            <div class="mb-2"><i class="fas fa-trophy fa-3x text-warning"></i></div>
            <h4 class="fw-bold text-purple">Winner: @Model.Winner?.FullName</h4>
            <p class="text-muted mb-0">@Model.Winner?.Party &nbsp;|&nbsp; @Model.Winner?.Constituency</p>
            <p class="text-muted small">Votes: @Model.Winner?.VoteCount</p>
        </div>
    }

    <!-- All Candidates -->
    <div class="card border-0 shadow-sm">
        <div class="card-header bg-white fw-bold">All Candidates</div>
        <div class="card-body">
            @if (!Model.AllCandidates.Any())
            {
                <p class="text-muted text-center">No candidates added yet.</p>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table align-middle">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Name</th>
                                <th>Party</th>
                                <th>Constituency</th>
                                <th>Votes</th>
                                @if (Model.TotalVotes > 0)
                                {
                                    <th>%</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @{ int rank = 1; }
                            @foreach (var c in Model.AllCandidates)
                            {
                                <tr class="@(Model.IsDeclared && c.Id == Model.Winner?.Id ? "table-success" : "")">
                                    <td>@rank</td>
                                    <td>@c.FullName @(Model.IsDeclared && c.Id == Model.Winner?.Id ? "🏆" : "")</td>
                                    <td><span class="badge bg-purple">@c.Party</span></td>
                                    <td>@c.Constituency</td>
                                    <td>@c.VoteCount</td>
                                    @if (Model.TotalVotes > 0)
                                    {
                                        <td>@((c.VoteCount * 100.0 / Model.TotalVotes).ToString("F1"))%</td>
                                    }
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
                <p class="text-muted small mt-2">Total Votes Cast: @Model.TotalVotes</p>
            }
        </div>
    </div>
</div>
