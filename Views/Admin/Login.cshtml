@model AdminLoginViewModel
@{
    ViewData["Title"] = "Admin Login";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4">
                <div class="text-end mb-2">
                    <a asp-controller="Admin" asp-action="Register" class="btn btn-sm btn-outline-secondary">Create Admin</a>
                </div>
                <h4 class="fw-bold text-center mb-1">Admin Login</h4>
                <p class="text-muted text-center small mb-4">Sign in to manage the election</p>

                <form asp-action="Login" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="helloAdmin@yopmail.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control" id="adminPassword" placeholder="Your password" />
                        <div class="form-check mt-1">
                            <input class="form-check-input" type="checkbox" id="showPass" onclick="togglePass()">
                            <label class="form-check-label small text-muted" for="showPass">Show password</label>
                        </div>
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-purple w-100">Login</button>
                    <p class="text-center text-muted small mt-3">No account? <a asp-controller="Admin" asp-action="Register">Create one</a></p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function togglePass() {
            var x = document.getElementById("adminPassword");
            x.type = x.type === "password" ? "text" : "password";
        }
    </script>
}
