@model AdminRegisterViewModel
@{
    ViewData["Title"] = "Create Admin Account";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card border-0 shadow-sm p-4">
                <div class="text-end mb-2">
                    <a asp-controller="Admin" asp-action="Login" class="btn btn-sm btn-outline-secondary">Admin Login</a>
                </div>
                <h4 class="fw-bold text-center mb-1">Create Admin Account</h4>
                <p class="text-muted text-center small mb-4">Register a new election administrator</p>

                <form asp-action="Register" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small" style="display:@(ViewContext.ModelState.IsValid ? "none" : "block")"></div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label small fw-semibold">Full Name</label>
                        <input asp-for="FullName" class="form-control" placeholder="Suman Bhattacharjee" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="Email" class="form-label small fw-semibold">Email</label>
                        <input asp-for="Email" class="form-control" placeholder="admin@votehub.com" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label asp-for="PhoneNumber" class="form-label small fw-semibold">Phone Number</label>
                        <input asp-for="PhoneNumber" class="form-control" placeholder="9836543605" />
                        <span asp-validation-for="PhoneNumber" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label asp-for="Password" class="form-label small fw-semibold">Password</label>
                        <input asp-for="Password" type="password" class="form-control" placeholder="Min. 6 characters" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>
                    <button type="submit" class="btn btn-purple w-100">Create Account</button>
                    <p class="text-center text-muted small mt-3">Already have an account? <a asp-controller="Admin" asp-action="Login">Login</a></p>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
