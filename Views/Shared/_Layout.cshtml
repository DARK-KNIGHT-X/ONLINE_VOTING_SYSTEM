<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - VoteHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" />
</head>
<body>
    <nav class="navbar navbar-expand-lg navbar-light bg-white shadow-sm py-3">
        <div class="container">
            <a class="navbar-brand fw-bold text-purple" asp-controller="Home" asp-action="Index">
                🗳️ VoteHub
            </a>
            <div class="ms-auto d-flex gap-2">
                @if (Context.Session.GetString("VoterId") != null)
                {
                    <span class="navbar-text me-2">Welcome, @Context.Session.GetString("VoterName")</span>
                    <a asp-controller="Voter" asp-action="Logout" class="btn btn-outline-purple btn-sm">Logout</a>
                }
                else if (Context.Session.GetString("AdminId") != null)
                {
                    <span class="navbar-text me-2">@Context.Session.GetString("AdminName")</span>
                    <a asp-controller="Admin" asp-action="Dashboard" class="btn btn-outline-purple btn-sm">Dashboard</a>
                    <a asp-controller="Admin" asp-action="Logout" class="btn btn-purple btn-sm">Logout</a>
                }
                else
                {
                    <a asp-controller="Voter" asp-action="Login" class="btn btn-outline-purple btn-sm">Voter Login</a>
                    <a asp-controller="Admin" asp-action="Login" class="btn btn-purple btn-sm">Admin</a>
                }
            </div>
        </div>
    </nav>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show m-0 rounded-0" role="alert">
            <div class="container">@TempData["Success"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show m-0 rounded-0" role="alert">
            <div class="container">@TempData["Error"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }
    @if (TempData["Info"] != null)
    {
        <div class="alert alert-info alert-dismissible fade show m-0 rounded-0" role="alert">
            <div class="container">@TempData["Info"]</div>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    <main>
        @RenderBody()
    </main>

    <footer class="footer py-3 bg-white border-top mt-5">
        <div class="container text-center text-muted small">
            &copy; 2026 VoteHub. All rights reserved. &nbsp;|&nbsp;
            <a href="#" class="text-muted text-decoration-none">Privacy</a> &nbsp;|&nbsp;
            <a href="#" class="text-muted text-decoration-none">Terms</a> &nbsp;|&nbsp;
            <a asp-controller="Home" asp-action="Results" class="text-muted text-decoration-none">Results</a>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @RenderSection("Scripts", required: false)
</body>
</html>
